<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Record 12 - Supervisor Checklist</title>

<style>

body{
margin:0;
font-family:Arial,Helvetica,sans-serif;
background:url("kitchen.jpg") center/cover fixed no-repeat;
}

.wash{
position:fixed;
inset:0;
background:rgba(255,255,255,.45);
backdrop-filter:blur(2px);
}

.page{
position:relative;
z-index:1;
max-width:1400px;
margin:auto;
padding:20px;
}

.mdk-toolbar{
display:flex;
gap:10px;
margin-bottom:14px;
flex-wrap:wrap;
align-items:center;
}

.mdk-btn--back{
background:#ffc107;
border:none;
color:#4b0082;
font-weight:700;
padding:10px 18px;
border-radius:12px;
cursor:pointer;
text-decoration:none;
}

.mdk-btn--pill{
background:#f8fafc;
border:1px solid #cfd6dd;
border-radius:12px;
padding:8px 14px;
font-weight:600;
cursor:pointer;
}

.mdk-btn--primary{
background:#007bff;
border:none;
border-radius:12px;
padding:10px 18px;
font-weight:600;
color:white;
cursor:pointer;
}

.sheet-card{
background:rgba(255,255,255,.95);
border-radius:20px;
box-shadow:0 12px 30px rgba(0,0,0,.14);
padding:20px;
}

.sheet-title{
font-size:28px;
font-weight:700;
margin-bottom:16px;
}

table{
width:100%;
border-collapse:collapse;
table-layout:fixed;
}

th,td{
border:1px solid #222;
padding:6px;
font-size:13px;
text-align:center;
}

th{
background:#f4f6f8;
}

input{
width:100%;
border:none;
background:transparent;
text-align:center;
}

@page{
size:A4 landscape;
margin:10mm;
}

@media print{

.mdk-toolbar{
display:none;
}

body{
background:white;
}

.wash{
display:none;
}

}

</style>
</head>

<body>

<div class="wash"></div>

<main class="page">

<div class="mdk-toolbar">

<a href="kitchen.html" class="mdk-btn--back">← Back</a>

<a href="dashboard.html" class="mdk-btn--pill">Home</a>

<button class="mdk-btn--pill" onclick="window.print()">Print</button>

<button class="mdk-btn--pill" onclick="clearForm()">Clear</button>

<button class="mdk-btn--primary" onclick="saveForm()">Save</button>

</div>

<div class="sheet-card">

<h1 class="sheet-title">Record 12 – Supervisor Checklist</h1>

<table>

<tr>
<th>Date</th>
<th>Supervisor</th>
<th>Food Handling</th>
<th>Temperature Control</th>
<th>Cleaning</th>
<th>Pest Control</th>
<th>Staff Hygiene</th>
<th>Corrective Action</th>
<th>Initial</th>
</tr>

<tbody id="tbody"></tbody>

</table>

</div>

</main>

<script>

const STORAGE="record12";

function row(){

let tr=document.createElement("tr");

for(let i=0;i<9;i++){

let td=document.createElement("td");
let input=document.createElement("input");

td.appendChild(input);
tr.appendChild(td);

}

return tr;

}

function build(){

let body=document.getElementById("tbody");

for(let i=0;i<15;i++){
body.appendChild(row());
}

}

function saveForm(){

let data=[];

document.querySelectorAll("input").forEach(i=>{
data.push(i.value);
});

localStorage.setItem(STORAGE,JSON.stringify(data));

alert("Saved");

}

function clearForm(){

if(!confirm("Clear form?")) return;

document.querySelectorAll("input").forEach(i=>i.value="");

localStorage.removeItem(STORAGE);

}

build();

</script>

</body>
</html>
